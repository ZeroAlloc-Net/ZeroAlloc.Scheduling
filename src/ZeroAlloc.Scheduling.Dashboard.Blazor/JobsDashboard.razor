@using ZeroAlloc.Scheduling
@inject JobsDashboardClient Client

<h2>ZeroAlloc Scheduler</h2>

@if (_error is not null)
{
    <p class="za-error">Error loading jobs: @_error</p>
}

@if (_summary is not null)
{
    <div class="za-cards">
        <div class="za-card"><div class="za-count">@_summary.Pending</div><div class="za-label">Pending</div></div>
        <div class="za-card"><div class="za-count">@_summary.Running</div><div class="za-label">Running</div></div>
        <div class="za-card"><div class="za-count">@_summary.Succeeded</div><div class="za-label">Succeeded</div></div>
        <div class="za-card"><div class="za-count">@_summary.Failed</div><div class="za-label">Failed</div></div>
        <div class="za-card"><div class="za-count">@_summary.DeadLetter</div><div class="za-label">Dead Letter</div></div>
    </div>
}

<table class="za-table">
    <thead>
        <tr><th>ID</th><th>Type</th><th>Status</th><th>Attempts</th><th>Scheduled</th><th>Error</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var job in _jobs)
        {
            <tr>
                <td title="@job.Id">@job.Id.ToString()[..8]&#x2026;</td>
                <td>@(job.TypeName.Split('.').LastOrDefault() ?? job.TypeName)</td>
                <td><span class="za-badge za-@job.Status">@job.Status</span></td>
                <td>@job.Attempts / @job.MaxAttempts</td>
                <td>@job.ScheduledAt.ToLocalTime().ToString("g")</td>
                <td>@job.Error</td>
                <td>
                    @if (job.Status == JobStatus.DeadLetter)
                    {
                        <button @onclick="() => RequeueAsync(job.Id)">Requeue</button>
                    }
                    <button @onclick="() => DeleteAsync(job.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private JobSummary? _summary;
    private List<JobEntry> _jobs = [];
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _error = null;
        try
        {
            _summary = await Client.GetSummaryAsync();
            var all = await Task.WhenAll(
                Client.GetPendingAsync(),
                Client.GetRunningAsync(),
                Client.GetFailedAsync(),
                Client.GetSucceededAsync());
            _jobs = all.Where(l => l != null).SelectMany(l => l!).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task RequeueAsync(Guid id) { await Client.RequeueAsync(id); await LoadAsync(); }
    private async Task DeleteAsync(Guid id)  { await Client.DeleteAsync(id);  await LoadAsync(); }
}
